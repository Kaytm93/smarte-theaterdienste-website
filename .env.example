# Supabase – aus dem Supabase-Dashboard übernehmen
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."        # nur server-seitig

# On-Demand-Revalidation (Webhook-Secret aus Supabase Trigger)
REVALIDATE_SECRET="ein-langes-zufaelliges-token"

# Resend (Kontaktformular) – später
RESEND_API_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
